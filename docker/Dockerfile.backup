FROM postgres:16-alpine

# Install aws-cli for S3 uploads
RUN apk add --no-cache aws-cli bash

COPY backup.sh /usr/local/bin/backup.sh
RUN chmod +x /usr/local/bin/backup.sh

# Default: run backup every hour via crond
RUN echo "0 * * * * /usr/local/bin/backup.sh >> /var/log/backup.log 2>&1" > /etc/crontabs/root

# Run initial backup on start, then hand off to cron
CMD ["/bin/bash", "-c", "/usr/local/bin/backup.sh && crond -f -l 2"]
